{
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "scripts": {
    "dev:web": "cd web && npm run dev",
    "dev:studio": "cd studio && npm run dev",
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:studio\"",
    "build:web": "cd web && npm run build",
    "build:studio": "cd studio && npm run build",
    "check:web": "cd web && npm run check",
    "check:studio": "cd studio && npm run check",
    "check": "npm run check:web && npm run check:studio",
    "install:web": "cd web && npm install",
    "install:studio": "cd studio && npm install",
    "install": "npm run install:all",
    "install:all": "npm run install:web && npm run install:studio",
    "deploy": "cd studio && npx sanity deploy",
    "push": "node scripts/push-and-deploy.mjs"
  }
}
