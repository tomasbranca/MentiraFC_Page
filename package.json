{
  "name": "mentira-fc",
  "private": true,
  "packageManager": "pnpm@10.34.1",
  "devDependencies": {
    "concurrently": "^10.0.3"
  },
  "scripts": {
    "dev:web": "pnpm --dir web dev",
    "dev:studio": "pnpm --dir studio dev",
    "dev": "concurrently \"pnpm dev:web\" \"pnpm dev:studio\"",
    "build:web": "pnpm --dir web build",
    "build:studio": "pnpm --dir studio build",
    "build": "pnpm build:web && pnpm build:studio",
    "lint:web": "pnpm --dir web lint",
    "lint:studio": "pnpm --dir studio lint",
    "lint": "pnpm lint:web && pnpm lint:studio",
    "test:web": "pnpm --dir web test",
    "test:studio": "pnpm --dir studio functions:unit",
    "test": "pnpm test:web && pnpm test:studio",
    "check:web": "pnpm --dir web check",
    "check:studio": "pnpm --dir studio check",
    "check": "pnpm check:web && pnpm check:studio",
    "deploy": "pnpm --dir studio run deploy && pnpm --dir studio run blueprints:deploy",
    "push": "node scripts/push-and-deploy.mjs"
  }
}
